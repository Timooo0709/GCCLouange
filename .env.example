# Variables d'environnement Firebase — copier vers .env.local pour le développement
# Sur Vercel : renseigner ces variables dans Project Settings > Environment Variables

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Notifications push (Web Push / PWA) ──────────────────────────────────────
# Générer la paire VAPID une fois :  npx web-push generate-vapid-keys
# La clé publique est exposée au navigateur, la privée reste côté serveur.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Identifiant de contact VAPID (mailto: ou https://). Ex : mailto:gcccfranco@gmail.com
VAPID_SUBJECT=mailto:gcccfranco@gmail.com

# Compte de service Firebase Admin (JSON de la clé privée, encodé en base64).
# Console Firebase > Paramètres du projet > Comptes de service > Générer une clé.
# Puis :  base64 -i serviceAccount.json | pbcopy
FIREBASE_SERVICE_ACCOUNT=

# Secret protégeant la route cron /api/cron/reminders (Vercel l'envoie en
# Authorization: Bearer <CRON_SECRET> sur les crons déclarés dans vercel.json).
CRON_SECRET=
