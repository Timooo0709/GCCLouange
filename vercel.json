{
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "crons": [
    { "path": "/api/cron/reminders", "schedule": "0 8 * * *" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
